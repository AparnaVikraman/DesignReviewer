OPENAI_API_KEY=your-openai-api-key-here
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/design_review

# Model & retrieval
MODEL_NAME=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
TOP_K=5
MAX_CHUNK_SIZE=600

# LLM client
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Logging
LOG_LEVEL=INFO
